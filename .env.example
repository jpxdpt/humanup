# Secret used to sign session JWTs. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=

# Postgres connection string. In Vercel: Project Settings -> Storage -> create a
# Postgres database and it's injected automatically. For local dev, use a local
# Postgres instance or a free Neon (neon.tech) database and paste its connection
# string here.
POSTGRES_URL=

# Bootstrap admin account, created on first run if the admins table is empty.
# Change the password after first login is not supported yet (no admin UI) —
# for now, update these and let the app reseed against a fresh database if needed.
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_NAME=
